{
  "name": "hamstersimulator",
  "displayName": "Hamster Simulator",
  "description": "Run and visualise Hamster programs (.ham) inside VS Code",
  "version": "0.2.0",
  "publisher": "DirkBretthauer",
  "license": "MIT",
  "repository": {
  "type": "git",
  "url": "https://github.com/DirkBretthauer/hamster-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hamster",
        "aliases": [
          "Hamster",
          "ham"
        ],
        "extensions": [
          ".ham"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hamster",
        "scopeName": "source.hamster",
        "path": "./syntaxes/hamster.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "hamster.openSimulator",
        "title": "Hamster: Open Simulator",
        "icon": "$(play)"
      },
      {
        "command": "hamster.run",
        "title": "Hamster: Run Program",
        "icon": "$(debug-start)"
      },
      {
        "command": "hamster.step",
        "title": "Hamster: Step",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "hamster.stop",
        "title": "Hamster: Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "hamster.reset",
        "title": "Hamster: Reset",
        "icon": "$(debug-restart)"
      }
    ],
    "customEditors": [
      {
        "viewType": "hamster.terrainEditor",
        "displayName": "Hamster Terrain Editor",
        "selector": [
          {
            "filenamePattern": "*.ter"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "hamster.openSimulator",
          "when": "resourceLangId == hamster",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map && vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
